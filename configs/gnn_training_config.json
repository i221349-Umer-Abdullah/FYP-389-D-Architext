{
  "training": {
    "epochs": 150,
    "batch_size": 64,
    "learning_rate": 0.001,
    "refiner_lr_multiplier": 0.5,
    "train_refiner_after_epoch": 25
  },

  "model": {
    "num_room_types": 10,
    "hidden_dim": 128,
    "num_gnn_layers": 3,
    "refiner_hidden_dim": 64
  },

  "loss": {
    "lambda_overlap": 0.5,
    "lambda_adjacency": 0.3
  },

  "optimizer": {
    "type": "Adam",
    "scheduler": {
      "type": "ReduceLROnPlateau",
      "mode": "min",
      "factor": 0.5,
      "patience": 5
    }
  },

  "data": {
    "train_file": "data/layout_training/cubicasa_train_lite.json",
    "val_split": 0.1,
    "num_workers": 4
  },

  "checkpointing": {
    "save_dir": "models/layout_gnn",
    "save_every_n_epochs": 10,
    "save_best_only": false
  },

  "gpu": {
    "device": "cuda",
    "mixed_precision": false
  },

  "comments": {
    "batch_size": "Current: 32. Can increase to 64-128 on RTX 3080 10GB for faster training",
    "learning_rate": "Current: 0.001 (safe). Can try 0.003-0.005 for faster convergence but may be unstable",
    "epochs": "50 epochs should take ~6-8 hours overnight",
    "refiner": "Starts training at epoch 25 to first learn good base positions"
  }
}
