# ArchiText — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit your real API keys.

# ─────────────────────────────────────────────────────────────────────────────
# LLM PROVIDER (choose one)
# ─────────────────────────────────────────────────────────────────────────────

# OPTION A: Groq — FREE, no credit card, fast LPU inference
#   Sign up at https://console.groq.com → API Keys → Create
LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# OPTION B: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# OPTION C: Anthropic (Claude)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# OPTION D: Ollama (fully local, no internet required)
#   Install from https://ollama.com → run: ollama pull llama3.2
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ─────────────────────────────────────────────────────────────────────────────
# GENERATOR MODE
# ─────────────────────────────────────────────────────────────────────────────
# "llm" = LLM generates room layouts directly (default, recommended)
# "gnn" = Use the trained StructuralGNN (requires gnn_best.pt)
GENERATOR_MODE=llm
